{
  "name": "@airstrings/cli",
  "version": "0.14.1",
  "description": "CLI for the AirStrings remote string management platform",
  "homepage": "https://airstrings.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/symbionix-sl/airstrings-cli.git",
    "directory": "npm"
  },
  "keywords": [
    "airstrings",
    "cli",
    "localization",
    "i18n",
    "strings"
  ],
  "bin": {
